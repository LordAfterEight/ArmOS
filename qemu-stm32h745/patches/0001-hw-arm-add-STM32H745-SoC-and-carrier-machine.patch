diff --git a/hw/misc/stm32h7_rcc.c b/hw/misc/stm32h7_rcc.c
new file mode 100644
index 0000000..8e7bc65
--- /dev/null
+++ b/hw/misc/stm32h7_rcc.c
@@ -0,0 +1,142 @@
+/*
+ * STM32H7 RCC — functional subset for firmware bring-up.
+ *
+ * Models CR ready bits, D1/D2 CFGR, and peripheral enable registers
+ * (AHB4/APB2/APB3/…) as read/write storage with HSE/HSI/PLL ready semantics.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qemu/log.h"
+#include "qemu/module.h"
+#include "hw/misc/stm32h7_rcc.h"
+#include "hw/qdev-properties.h"
+#include "migration/vmstate.h"
+
+static void stm32h7_rcc_reset(DeviceState *dev)
+{
+    STM32H7RccState *s = STM32H7_RCC(dev);
+    int i;
+
+    for (i = 0; i < STM32H7_RCC_NREGS; i++) {
+        s->regs[i] = 0;
+    }
+
+    /* HSI on and ready after reset (64 MHz class on H7). */
+    s->regs[STM32H7_RCC_CR / 4] = STM32H7_RCC_CR_HSION | STM32H7_RCC_CR_HSIRDY;
+}
+
+static uint64_t stm32h7_rcc_read(void *opaque, hwaddr addr, unsigned size)
+{
+    STM32H7RccState *s = opaque;
+    uint32_t index = addr / 4;
+
+    if (addr >= 0x200 || (addr & 3)) {
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad read offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+        return 0;
+    }
+
+    return s->regs[index];
+}
+
+static void stm32h7_rcc_write(void *opaque, hwaddr addr,
+                              uint64_t val64, unsigned size)
+{
+    STM32H7RccState *s = opaque;
+    uint32_t value = val64;
+    uint32_t index = addr / 4;
+    uint32_t cr;
+
+    if (addr >= 0x200 || (addr & 3)) {
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad write offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+        return;
+    }
+
+    switch (addr) {
+    case STM32H7_RCC_CR:
+        cr = value;
+        /* HSI always ready when requested on. */
+        if (cr & STM32H7_RCC_CR_HSION) {
+            cr |= STM32H7_RCC_CR_HSIRDY;
+        } else {
+            cr &= ~STM32H7_RCC_CR_HSIRDY;
+        }
+        /* HSE ready only if board has a crystal and software enables it. */
+        if ((cr & STM32H7_RCC_CR_HSEON) && s->hse_frequency) {
+            cr |= STM32H7_RCC_CR_HSERDY;
+        } else {
+            cr &= ~STM32H7_RCC_CR_HSERDY;
+        }
+        /* Instant PLL lock when enabled (simplified). */
+        if (cr & STM32H7_RCC_CR_PLL1ON) {
+            cr |= STM32H7_RCC_CR_PLL1RDY;
+        } else {
+            cr &= ~STM32H7_RCC_CR_PLL1RDY;
+        }
+        s->regs[index] = cr;
+        break;
+    default:
+        s->regs[index] = value;
+        break;
+    }
+}
+
+static const MemoryRegionOps stm32h7_rcc_ops = {
+    .read = stm32h7_rcc_read,
+    .write = stm32h7_rcc_write,
+    .endianness = DEVICE_NATIVE_ENDIAN,
+    .valid.min_access_size = 4,
+    .valid.max_access_size = 4,
+};
+
+static const VMStateDescription vmstate_stm32h7_rcc = {
+    .name = TYPE_STM32H7_RCC,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (const VMStateField[]) {
+        VMSTATE_UINT32_ARRAY(regs, STM32H7RccState, STM32H7_RCC_NREGS),
+        VMSTATE_END_OF_LIST()
+    }
+};
+
+static const Property stm32h7_rcc_properties[] = {
+    DEFINE_PROP_UINT32("hse-frequency", STM32H7RccState, hse_frequency, 0),
+};
+
+static void stm32h7_rcc_init(Object *obj)
+{
+    STM32H7RccState *s = STM32H7_RCC(obj);
+
+    memory_region_init_io(&s->mmio, obj, &stm32h7_rcc_ops, s,
+                          TYPE_STM32H7_RCC, 0x400);
+    sysbus_init_mmio(SYS_BUS_DEVICE(obj), &s->mmio);
+}
+
+static void stm32h7_rcc_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    device_class_set_legacy_reset(dc, stm32h7_rcc_reset);
+    device_class_set_props(dc, stm32h7_rcc_properties);
+    dc->vmsd = &vmstate_stm32h7_rcc;
+}
+
+static const TypeInfo stm32h7_rcc_info = {
+    .name = TYPE_STM32H7_RCC,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(STM32H7RccState),
+    .instance_init = stm32h7_rcc_init,
+    .class_init = stm32h7_rcc_class_init,
+};
+
+static void stm32h7_rcc_register_types(void)
+{
+    type_register_static(&stm32h7_rcc_info);
+}
+
+type_init(stm32h7_rcc_register_types)
diff --git a/include/hw/arm/stm32h745_soc.h b/include/hw/arm/stm32h745_soc.h
new file mode 100644
index 0000000..3d07dad
--- /dev/null
+++ b/include/hw/arm/stm32h745_soc.h
@@ -0,0 +1,72 @@
+/*
+ * STM32H745 SoC (Cortex-M7 bring-up subset)
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef HW_ARM_STM32H745_SOC_H
+#define HW_ARM_STM32H745_SOC_H
+
+#include "hw/arm/armv7m.h"
+#include "hw/char/stm32h7_usart.h"
+#include "hw/gpio/stm32h7_gpio.h"
+#include "hw/misc/stm32h7_rcc.h"
+#include "hw/clock.h"
+#include "qom/object.h"
+
+#define TYPE_STM32H745_SOC "stm32h745-soc"
+OBJECT_DECLARE_SIMPLE_TYPE(STM32H745State, STM32H745_SOC)
+
+#define STM32H745_NUM_GPIO  11  /* A..K */
+#define STM32H745_NUM_USART 1   /* USART1 for console; expand later */
+
+#define STM32H745_FLASH_BASE     0x08000000
+#define STM32H745_FLASH_SIZE     (2 * 1024 * 1024)
+#define STM32H745_DTCM_BASE      0x20000000
+#define STM32H745_DTCM_SIZE      (128 * 1024)
+#define STM32H745_AXI_SRAM_BASE  0x24000000
