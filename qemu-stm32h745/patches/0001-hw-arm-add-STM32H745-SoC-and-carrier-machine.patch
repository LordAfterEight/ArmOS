+/*
+ * STM32H7 USART (CR1/ISR/TDR layout — same family as L4/F0 “new” USART)
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef HW_CHAR_STM32H7_USART_H
+#define HW_CHAR_STM32H7_USART_H
+
+#include "hw/sysbus.h"
+#include "chardev/char-fe.h"
+#include "qom/object.h"
+
+#define TYPE_STM32H7_USART "stm32h7-usart"
+OBJECT_DECLARE_SIMPLE_TYPE(STM32H7UsartState, STM32H7_USART)
+
+#define STM32H7_USART_CR1  0x00
+#define STM32H7_USART_CR2  0x04
+#define STM32H7_USART_CR3  0x08
+#define STM32H7_USART_BRR  0x0C
+#define STM32H7_USART_GTPR 0x10
+#define STM32H7_USART_RTOR 0x14
+#define STM32H7_USART_RQR  0x18
+#define STM32H7_USART_ISR  0x1C
+#define STM32H7_USART_ICR  0x20
+#define STM32H7_USART_RDR  0x24
+#define STM32H7_USART_TDR  0x28
+#define STM32H7_USART_PRESC 0x2C
+
+#define STM32H7_USART_CR1_UE    (1u << 0)
+#define STM32H7_USART_CR1_RE    (1u << 2)
+#define STM32H7_USART_CR1_TE    (1u << 3)
+#define STM32H7_USART_CR1_RXNEIE (1u << 5)
+#define STM32H7_USART_CR1_TCIE  (1u << 6)
+#define STM32H7_USART_CR1_TXEIE (1u << 7)
+
+#define STM32H7_USART_ISR_RXNE  (1u << 5)
+#define STM32H7_USART_ISR_TC    (1u << 6)
+#define STM32H7_USART_ISR_TXE   (1u << 7)
+#define STM32H7_USART_ISR_TEACK (1u << 21)
+#define STM32H7_USART_ISR_REACK (1u << 22)
+
+struct STM32H7UsartState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion mmio;
+
+    uint32_t cr1;
+    uint32_t cr2;
+    uint32_t cr3;
+    uint32_t brr;
+    uint32_t gtpr;
+    uint32_t rtor;
+    uint32_t isr;
+    uint32_t rdr;
+    uint32_t tdr;
+    uint32_t presc;
+
+    CharBackend chr;
+    qemu_irq irq;
+};
+
+#endif /* HW_CHAR_STM32H7_USART_H */
