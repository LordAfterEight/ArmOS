diff --git a/include/hw/misc/stm32h7_rcc.h b/include/hw/misc/stm32h7_rcc.h
new file mode 100644
index 0000000..5392f87
--- /dev/null
+++ b/include/hw/misc/stm32h7_rcc.h
@@ -0,0 +1,54 @@
+/*
+ * STM32H7 RCC (minimal: ENR/CFGR/CR enough for bring-up)
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef HW_MISC_STM32H7_RCC_H
+#define HW_MISC_STM32H7_RCC_H
+
+#include "hw/sysbus.h"
+#include "qom/object.h"
+
+#define TYPE_STM32H7_RCC "stm32h7-rcc"
+OBJECT_DECLARE_SIMPLE_TYPE(STM32H7RccState, STM32H7_RCC)
+
+/* Register offsets (RM0399 / stm32h7 PAC) */
+#define STM32H7_RCC_CR          0x00
+#define STM32H7_RCC_HSICFGR     0x04
+#define STM32H7_RCC_CRRCR       0x08
+#define STM32H7_RCC_CSICFGR     0x0C
+#define STM32H7_RCC_CFGR        0x10
+#define STM32H7_RCC_D1CFGR      0x18
+#define STM32H7_RCC_D2CFGR      0x1C
+#define STM32H7_RCC_D3CFGR      0x20
+#define STM32H7_RCC_PLLCKSELR   0x28
+#define STM32H7_RCC_PLLCFGR     0x2C
+#define STM32H7_RCC_PLL1DIVR    0x30
+#define STM32H7_RCC_AHB4ENR     0xE0
+#define STM32H7_RCC_APB3ENR     0xE4
+#define STM32H7_RCC_APB1LENR    0xE8
+#define STM32H7_RCC_APB1HENR    0xEC
+#define STM32H7_RCC_APB2ENR     0xF0
+#define STM32H7_RCC_APB4ENR     0xF4
+
+#define STM32H7_RCC_CR_HSION    (1u << 0)
+#define STM32H7_RCC_CR_HSIRDY   (1u << 2)
+#define STM32H7_RCC_CR_HSEON    (1u << 16)
+#define STM32H7_RCC_CR_HSERDY   (1u << 17)
+#define STM32H7_RCC_CR_PLL1ON   (1u << 24)
+#define STM32H7_RCC_CR_PLL1RDY  (1u << 25)
+
+#define STM32H7_RCC_NREGS       (0x200 / 4)
+
+struct STM32H7RccState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion mmio;
+    uint32_t regs[STM32H7_RCC_NREGS];
+
+    /* Board-supplied HSE frequency (Hz); 0 means no crystal. */
+    uint32_t hse_frequency;
+};
+
+#endif /* HW_MISC_STM32H7_RCC_H */
