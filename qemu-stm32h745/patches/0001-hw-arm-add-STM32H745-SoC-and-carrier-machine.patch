diff --git a/hw/char/stm32h7_usart.c b/hw/char/stm32h7_usart.c
new file mode 100644
index 0000000..05159e3
--- /dev/null
+++ b/hw/char/stm32h7_usart.c
@@ -0,0 +1,277 @@
+/*
+ * STM32H7 USART — polling TX/RX for console bring-up.
+ *
+ * Register map matches the “new” ST USART (H7/L4): CR1@0, ISR@0x1C, TDR@0x28.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qemu/log.h"
+#include "qemu/module.h"
+#include "hw/char/stm32h7_usart.h"
+#include "hw/irq.h"
+#include "hw/qdev-properties.h"
+#include "hw/qdev-properties-system.h"
+#include "migration/vmstate.h"
+
+static void stm32h7_usart_update_irq(STM32H7UsartState *s)
+{
+    bool raise = false;
+
+    if ((s->isr & STM32H7_USART_ISR_TXE) && (s->cr1 & STM32H7_USART_CR1_TXEIE)) {
+        raise = true;
+    }
+    if ((s->isr & STM32H7_USART_ISR_TC) && (s->cr1 & STM32H7_USART_CR1_TCIE)) {
+        raise = true;
+    }
+    if ((s->isr & STM32H7_USART_ISR_RXNE) && (s->cr1 & STM32H7_USART_CR1_RXNEIE)) {
+        raise = true;
+    }
+
+    qemu_set_irq(s->irq, raise);
+}
+
+static void stm32h7_usart_update_ack(STM32H7UsartState *s)
+{
+    if (s->cr1 & STM32H7_USART_CR1_TE) {
+        s->isr |= STM32H7_USART_ISR_TEACK | STM32H7_USART_ISR_TXE |
+                  STM32H7_USART_ISR_TC;
+    } else {
+        s->isr &= ~STM32H7_USART_ISR_TEACK;
+    }
+    if (s->cr1 & STM32H7_USART_CR1_RE) {
+        s->isr |= STM32H7_USART_ISR_REACK;
+    } else {
+        s->isr &= ~STM32H7_USART_ISR_REACK;
+    }
+}
+
+static int stm32h7_usart_can_receive(void *opaque)
+{
+    STM32H7UsartState *s = opaque;
+
+    return !(s->isr & STM32H7_USART_ISR_RXNE);
+}
+
+static void stm32h7_usart_receive(void *opaque, const uint8_t *buf, int size)
+{
+    STM32H7UsartState *s = opaque;
+
+    if (!(s->cr1 & STM32H7_USART_CR1_UE) || !(s->cr1 & STM32H7_USART_CR1_RE)) {
+        return;
+    }
+
+    s->rdr = *buf;
+    s->isr |= STM32H7_USART_ISR_RXNE;
+    stm32h7_usart_update_irq(s);
+}
+
+static void stm32h7_usart_reset(DeviceState *dev)
+{
+    STM32H7UsartState *s = STM32H7_USART(dev);
+
+    s->cr1 = 0;
+    s->cr2 = 0;
+    s->cr3 = 0;
+    s->brr = 0;
+    s->gtpr = 0;
+    s->rtor = 0;
+    s->isr = STM32H7_USART_ISR_TXE | STM32H7_USART_ISR_TC;
+    s->rdr = 0;
+    s->tdr = 0;
+    s->presc = 0;
+    stm32h7_usart_update_irq(s);
+}
+
+static uint64_t stm32h7_usart_read(void *opaque, hwaddr addr, unsigned size)
+{
+    STM32H7UsartState *s = opaque;
+    uint64_t value = 0;
+
+    switch (addr) {
+    case STM32H7_USART_CR1:
+        value = s->cr1;
+        break;
+    case STM32H7_USART_CR2:
+        value = s->cr2;
+        break;
+    case STM32H7_USART_CR3:
+        value = s->cr3;
+        break;
+    case STM32H7_USART_BRR:
+        value = s->brr;
+        break;
+    case STM32H7_USART_GTPR:
+        value = s->gtpr;
+        break;
+    case STM32H7_USART_RTOR:
+        value = s->rtor;
+        break;
+    case STM32H7_USART_ISR:
+        value = s->isr;
+        qemu_chr_fe_accept_input(&s->chr);
+        break;
+    case STM32H7_USART_RDR:
+        value = s->rdr & 0x1FF;
+        s->isr &= ~STM32H7_USART_ISR_RXNE;
+        qemu_chr_fe_accept_input(&s->chr);
+        stm32h7_usart_update_irq(s);
+        break;
+    case STM32H7_USART_TDR:
+        value = s->tdr;
+        break;
+    case STM32H7_USART_PRESC:
+        value = s->presc;
+        break;
+    case STM32H7_USART_RQR:
+    case STM32H7_USART_ICR:
+        value = 0;
+        break;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad read offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+        break;
+    }
+
+    return value;
+}
+
+static void stm32h7_usart_write(void *opaque, hwaddr addr,
+                                uint64_t val64, unsigned size)
+{
+    STM32H7UsartState *s = opaque;
+    uint32_t value = val64;
+    uint8_t ch;
+
+    switch (addr) {
+    case STM32H7_USART_CR1:
+        s->cr1 = value;
+        stm32h7_usart_update_ack(s);
+        stm32h7_usart_update_irq(s);
+        break;
+    case STM32H7_USART_CR2:
+        s->cr2 = value;
+        break;
+    case STM32H7_USART_CR3:
+        s->cr3 = value;
+        break;
+    case STM32H7_USART_BRR:
+        s->brr = value & 0xFFFF;
+        break;
+    case STM32H7_USART_GTPR:
+        s->gtpr = value;
+        break;
+    case STM32H7_USART_RTOR:
+        s->rtor = value;
+        break;
+    case STM32H7_USART_RQR:
+        if (value & (1u << 3)) { /* RXFRQ */
+            s->isr &= ~STM32H7_USART_ISR_RXNE;
+        }
+        stm32h7_usart_update_irq(s);
+        break;
+    case STM32H7_USART_ICR:
+        /* Clear corresponding ISR flags (bit layout matches ICR). */
+        s->isr &= ~value;
+        /* TXE is read-only high when TE is set. */
+        stm32h7_usart_update_ack(s);
+        stm32h7_usart_update_irq(s);
+        break;
+    case STM32H7_USART_TDR:
+        s->tdr = value & 0x1FF;
+        if ((s->cr1 & STM32H7_USART_CR1_UE) && (s->cr1 & STM32H7_USART_CR1_TE)) {
+            ch = value;
+            qemu_chr_fe_write_all(&s->chr, &ch, 1);
+            s->isr |= STM32H7_USART_ISR_TXE | STM32H7_USART_ISR_TC;
+            stm32h7_usart_update_irq(s);
+        }
+        break;
+    case STM32H7_USART_PRESC:
+        s->presc = value & 0xF;
+        break;
+    case STM32H7_USART_ISR:
+    case STM32H7_USART_RDR:
+        /* Read-only / clear via ICR. */
+        break;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad write offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+        break;
+    }
+}
+
+static const MemoryRegionOps stm32h7_usart_ops = {
+    .read = stm32h7_usart_read,
+    .write = stm32h7_usart_write,
+    .endianness = DEVICE_NATIVE_ENDIAN,
+};
+
+static const VMStateDescription vmstate_stm32h7_usart = {
+    .name = TYPE_STM32H7_USART,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (const VMStateField[]) {
+        VMSTATE_UINT32(cr1, STM32H7UsartState),
+        VMSTATE_UINT32(cr2, STM32H7UsartState),
+        VMSTATE_UINT32(cr3, STM32H7UsartState),
+        VMSTATE_UINT32(brr, STM32H7UsartState),
+        VMSTATE_UINT32(gtpr, STM32H7UsartState),
+        VMSTATE_UINT32(rtor, STM32H7UsartState),
+        VMSTATE_UINT32(isr, STM32H7UsartState),
+        VMSTATE_UINT32(rdr, STM32H7UsartState),
+        VMSTATE_UINT32(tdr, STM32H7UsartState),
+        VMSTATE_UINT32(presc, STM32H7UsartState),
+        VMSTATE_END_OF_LIST()
+    }
+};
+
+static const Property stm32h7_usart_properties[] = {
+    DEFINE_PROP_CHR("chardev", STM32H7UsartState, chr),
+};
+
+static void stm32h7_usart_init(Object *obj)
+{
+    STM32H7UsartState *s = STM32H7_USART(obj);
+
+    sysbus_init_irq(SYS_BUS_DEVICE(obj), &s->irq);
+    memory_region_init_io(&s->mmio, obj, &stm32h7_usart_ops, s,
+                          TYPE_STM32H7_USART, 0x400);
+    sysbus_init_mmio(SYS_BUS_DEVICE(obj), &s->mmio);
+}
+
+static void stm32h7_usart_realize(DeviceState *dev, Error **errp)
+{
+    STM32H7UsartState *s = STM32H7_USART(dev);
+
+    qemu_chr_fe_set_handlers(&s->chr, stm32h7_usart_can_receive,
+                             stm32h7_usart_receive, NULL, NULL,
+                             s, NULL, true);
+}
+
+static void stm32h7_usart_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    device_class_set_legacy_reset(dc, stm32h7_usart_reset);
+    device_class_set_props(dc, stm32h7_usart_properties);
+    dc->realize = stm32h7_usart_realize;
+    dc->vmsd = &vmstate_stm32h7_usart;
+}
+
+static const TypeInfo stm32h7_usart_info = {
+    .name = TYPE_STM32H7_USART,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(STM32H7UsartState),
+    .instance_init = stm32h7_usart_init,
+    .class_init = stm32h7_usart_class_init,
+};
+
+static void stm32h7_usart_register_types(void)
+{
+    type_register_static(&stm32h7_usart_info);
+}
+
+type_init(stm32h7_usart_register_types)
