diff --git a/hw/gpio/stm32h7_gpio.c b/hw/gpio/stm32h7_gpio.c
new file mode 100644
index 0000000..1562b7c
--- /dev/null
+++ b/hw/gpio/stm32h7_gpio.c
@@ -0,0 +1,190 @@
+/*
+ * STM32H7 GPIO — enough for AF pin mux and simple output.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qemu/log.h"
+#include "qemu/module.h"
+#include "hw/gpio/stm32h7_gpio.h"
+#include "hw/irq.h"
+#include "hw/qdev-properties.h"
+#include "migration/vmstate.h"
+
+static void stm32h7_gpio_update_outputs(STM32H7GpioState *s)
+{
+    int i;
+
+    for (i = 0; i < 16; i++) {
+        /* Mode 01 = general purpose output. */
+        if (extract32(s->moder, i * 2, 2) == 1) {
+            qemu_set_irq(s->output[i], extract32(s->odr, i, 1));
+        }
+    }
+}
+
+static void stm32h7_gpio_reset(DeviceState *dev)
+{
+    STM32H7GpioState *s = STM32H7_GPIO(dev);
+
+    s->moder = s->moder_reset;
+    s->otyper = 0;
+    s->ospeedr = 0;
+    s->pupdr = 0;
+    s->idr = 0;
+    s->odr = 0;
+    s->lckr = 0;
+    s->afrl = 0;
+    s->afrh = 0;
+}
+
+static uint64_t stm32h7_gpio_read(void *opaque, hwaddr addr, unsigned size)
+{
+    STM32H7GpioState *s = opaque;
+
+    switch (addr) {
+    case STM32H7_GPIO_MODER:
+        return s->moder;
+    case STM32H7_GPIO_OTYPER:
+        return s->otyper;
+    case STM32H7_GPIO_OSPEEDR:
+        return s->ospeedr;
+    case STM32H7_GPIO_PUPDR:
+        return s->pupdr;
+    case STM32H7_GPIO_IDR:
+        return s->idr | s->odr;
+    case STM32H7_GPIO_ODR:
+        return s->odr;
+    case STM32H7_GPIO_LCKR:
+        return s->lckr;
+    case STM32H7_GPIO_AFRL:
+        return s->afrl;
+    case STM32H7_GPIO_AFRH:
+        return s->afrh;
+    case STM32H7_GPIO_BSRR:
+        return 0;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad read offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+        return 0;
+    }
+}
+
+static void stm32h7_gpio_write(void *opaque, hwaddr addr,
+                               uint64_t val64, unsigned size)
+{
+    STM32H7GpioState *s = opaque;
+    uint32_t value = val64;
+    uint32_t set, reset;
+
+    switch (addr) {
+    case STM32H7_GPIO_MODER:
+        s->moder = value;
+        stm32h7_gpio_update_outputs(s);
+        break;
+    case STM32H7_GPIO_OTYPER:
+        s->otyper = value & 0xFFFF;
+        break;
+    case STM32H7_GPIO_OSPEEDR:
+        s->ospeedr = value;
+        break;
+    case STM32H7_GPIO_PUPDR:
+        s->pupdr = value;
+        break;
+    case STM32H7_GPIO_ODR:
+        s->odr = value & 0xFFFF;
+        stm32h7_gpio_update_outputs(s);
+        break;
+    case STM32H7_GPIO_BSRR:
+        set = value & 0xFFFF;
+        reset = (value >> 16) & 0xFFFF;
+        s->odr = (s->odr | set) & ~reset;
+        stm32h7_gpio_update_outputs(s);
+        break;
+    case STM32H7_GPIO_LCKR:
+        s->lckr = value;
+        break;
+    case STM32H7_GPIO_AFRL:
+        s->afrl = value;
+        break;
+    case STM32H7_GPIO_AFRH:
+        s->afrh = value;
+        break;
+    case STM32H7_GPIO_IDR:
+        /* Read-only. */
+        break;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad write offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+        break;
+    }
+}
+
+static const MemoryRegionOps stm32h7_gpio_ops = {
+    .read = stm32h7_gpio_read,
+    .write = stm32h7_gpio_write,
+    .endianness = DEVICE_NATIVE_ENDIAN,
+    .valid.min_access_size = 4,
+    .valid.max_access_size = 4,
+};
+
+static const VMStateDescription vmstate_stm32h7_gpio = {
+    .name = TYPE_STM32H7_GPIO,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (const VMStateField[]) {
+        VMSTATE_UINT32(moder, STM32H7GpioState),
+        VMSTATE_UINT32(otyper, STM32H7GpioState),
+        VMSTATE_UINT32(ospeedr, STM32H7GpioState),
+        VMSTATE_UINT32(pupdr, STM32H7GpioState),
+        VMSTATE_UINT32(idr, STM32H7GpioState),
+        VMSTATE_UINT32(odr, STM32H7GpioState),
+        VMSTATE_UINT32(lckr, STM32H7GpioState),
+        VMSTATE_UINT32(afrl, STM32H7GpioState),
+        VMSTATE_UINT32(afrh, STM32H7GpioState),
+        VMSTATE_END_OF_LIST()
+    }
+};
+
+static const Property stm32h7_gpio_properties[] = {
+    DEFINE_PROP_UINT32("moder-reset", STM32H7GpioState, moder_reset, 0xFFFFFFFF),
+    DEFINE_PROP_STRING("name", STM32H7GpioState, name),
+};
+
+static void stm32h7_gpio_init(Object *obj)
+{
+    STM32H7GpioState *s = STM32H7_GPIO(obj);
+    DeviceState *dev = DEVICE(obj);
+
+    memory_region_init_io(&s->mmio, obj, &stm32h7_gpio_ops, s,
+                          TYPE_STM32H7_GPIO, 0x400);
+    sysbus_init_mmio(SYS_BUS_DEVICE(obj), &s->mmio);
+    qdev_init_gpio_out(dev, s->output, 16);
+}
+
+static void stm32h7_gpio_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    device_class_set_legacy_reset(dc, stm32h7_gpio_reset);
+    device_class_set_props(dc, stm32h7_gpio_properties);
+    dc->vmsd = &vmstate_stm32h7_gpio;
+}
+
+static const TypeInfo stm32h7_gpio_info = {
+    .name = TYPE_STM32H7_GPIO,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(STM32H7GpioState),
+    .instance_init = stm32h7_gpio_init,
+    .class_init = stm32h7_gpio_class_init,
+};
+
+static void stm32h7_gpio_register_types(void)
+{
+    type_register_static(&stm32h7_gpio_info);
+}
+
+type_init(stm32h7_gpio_register_types)
