diff --git a/hw/arm/stm32h745_carrier.c b/hw/arm/stm32h745_carrier.c
new file mode 100644
index 0000000..a0647e2
--- /dev/null
+++ b/hw/arm/stm32h745_carrier.c
@@ -0,0 +1,58 @@
+/*
+ * Custom STM32H745BIT6 MCU carrier board
+ *
+ * - 8 MHz HSE on OSC_IN (PH0)
+ * - 64 MiB FMC SDRAM (AS4C32M16SB) at 0xC0000000
+ * - Console: USART1 (chardev serial0)
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qapi/error.h"
+#include "hw/boards.h"
+#include "hw/qdev-clock.h"
+#include "hw/qdev-properties.h"
+#include "hw/arm/stm32h745_soc.h"
+#include "hw/arm/boot.h"
+#include "qemu/error-report.h"
+
+/* HSI default 64 MHz until guest programs PLLs. */
+#define SYSCLK_FRQ 64000000ULL
+#define HSE_FRQ    8000000ULL
+
+static void stm32h745_carrier_init(MachineState *machine)
+{
+    DeviceState *dev;
+    Clock *sysclk;
+
+    sysclk = clock_new(OBJECT(machine), "SYSCLK");
+    clock_set_hz(sysclk, SYSCLK_FRQ);
+
+    dev = qdev_new(TYPE_STM32H745_SOC);
+    object_property_add_child(OBJECT(machine), "soc", OBJECT(dev));
+    qdev_prop_set_uint32(dev, "hse-frequency", HSE_FRQ);
+    qdev_prop_set_uint64(dev, "sdram-size", STM32H745_SDRAM_SIZE);
+    qdev_connect_clock_in(dev, "sysclk", sysclk);
+    sysbus_realize_and_unref(SYS_BUS_DEVICE(dev), &error_fatal);
+
+    armv7m_load_kernel(STM32H745_SOC(dev)->armv7m.cpu,
+                       machine->kernel_filename,
+                       STM32H745_FLASH_BASE,
+                       STM32H745_FLASH_SIZE);
+}
+
+static void stm32h745_carrier_machine_init(MachineClass *mc)
+{
+    static const char *const valid_cpu_types[] = {
+        ARM_CPU_TYPE_NAME("cortex-m7"),
+        NULL
+    };
+
+    mc->desc = "STM32H745BIT6 custom carrier (Cortex-M7)";
+    mc->init = stm32h745_carrier_init;
+    mc->valid_cpu_types = valid_cpu_types;
+    mc->default_cpu_type = ARM_CPU_TYPE_NAME("cortex-m7");
+}
+
+DEFINE_MACHINE("stm32h745-carrier", stm32h745_carrier_machine_init)
diff --git a/hw/arm/stm32h745_soc.c b/hw/arm/stm32h745_soc.c
new file mode 100644
index 0000000..0a10051
--- /dev/null
+++ b/hw/arm/stm32h745_soc.c
@@ -0,0 +1,245 @@
+/*
+ * STM32H745 SoC
+ *
+ * Cortex-M7 + flash/SRAM map + RCC + GPIO + USART1.
+ * Carrier board attaches SDRAM size / HSE via properties.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qapi/error.h"
+#include "system/address-spaces.h"
+#include "system/system.h"
+#include "hw/arm/stm32h745_soc.h"
+#include "hw/qdev-clock.h"
+#include "hw/qdev-properties.h"
+#include "hw/misc/unimp.h"
+#include "qemu/module.h"
+
+static const hwaddr gpio_addr[STM32H745_NUM_GPIO] = {
+    0x58020000, /* A */
+    0x58020400, /* B */
+    0x58020800, /* C */
+    0x58020C00, /* D */
+    0x58021000, /* E */
+    0x58021400, /* F */
+    0x58021800, /* G */
+    0x58021C00, /* H */
+    0x58022000, /* I */
+    0x58022400, /* J */
+    0x58022800, /* K */
+};
+
+static const char *gpio_name[STM32H745_NUM_GPIO] = {
+    "A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "K"
+};
+
+/* GPIOA debug pins reset closer to silicon; others default analog. */
+static const uint32_t gpio_moder_reset[STM32H745_NUM_GPIO] = {
+    0xABFFFFFF, /* A */
+    0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF,
+    0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF,
+};
+
+static void stm32h745_soc_initfn(Object *obj)
+{
+    STM32H745State *s = STM32H745_SOC(obj);
+    int i;
+
+    object_initialize_child(obj, "armv7m", &s->armv7m, TYPE_ARMV7M);
+    object_initialize_child(obj, "rcc", &s->rcc, TYPE_STM32H7_RCC);
+
+    for (i = 0; i < STM32H745_NUM_GPIO; i++) {
+        object_initialize_child(obj, "gpio[*]", &s->gpio[i], TYPE_STM32H7_GPIO);
+    }
+
+    object_initialize_child(obj, "usart1", &s->usart1, TYPE_STM32H7_USART);
+
+    s->sysclk = qdev_init_clock_in(DEVICE(s), "sysclk", NULL, NULL, 0);
+    s->refclk = qdev_init_clock_in(DEVICE(s), "refclk", NULL, NULL, 0);
+}
+
+static void stm32h745_soc_realize(DeviceState *dev_soc, Error **errp)
+{
+    STM32H745State *s = STM32H745_SOC(dev_soc);
+    MemoryRegion *system_memory = get_system_memory();
+    DeviceState *armv7m, *dev;
+    SysBusDevice *busdev;
+    Error *err = NULL;
+    int i;
+
+    if (clock_has_source(s->refclk)) {
+        error_setg(errp, "refclk must not be wired by the board");
+        return;
+    }
+    if (!clock_has_source(s->sysclk)) {
+        error_setg(errp, "sysclk must be wired by the board");
+        return;
+    }
+
+    /* SysTick refclk = HCLK / 8 (fixed for now). */
+    clock_set_mul_div(s->refclk, 8, 1);
+    clock_set_source(s->refclk, s->sysclk);
+
+    memory_region_init_rom(&s->flash, OBJECT(dev_soc), "stm32h745.flash",
+                           STM32H745_FLASH_SIZE, &err);
+    if (err) {
+        error_propagate(errp, err);
+        return;
+    }
+    memory_region_init_alias(&s->flash_alias, OBJECT(dev_soc),
+                             "stm32h745.flash.alias", &s->flash, 0,
+                             STM32H745_FLASH_SIZE);
+    memory_region_add_subregion(system_memory, STM32H745_FLASH_BASE, &s->flash);
+    /* Boot remap: flash visible at 0 for initial SP/PC fetch. */
+    memory_region_add_subregion(system_memory, 0, &s->flash_alias);
+
+    memory_region_init_ram(&s->dtcm, NULL, "stm32h745.dtcm",
+                           STM32H745_DTCM_SIZE, &err);
+    if (err) {
+        error_propagate(errp, err);
+        return;
+    }
+    memory_region_add_subregion(system_memory, STM32H745_DTCM_BASE, &s->dtcm);
+
+    memory_region_init_ram(&s->axi_sram, NULL, "stm32h745.axi-sram",
+                           STM32H745_AXI_SRAM_SIZE, &err);
+    if (err) {
+        error_propagate(errp, err);
+        return;
+    }
+    memory_region_add_subregion(system_memory, STM32H745_AXI_SRAM_BASE,
+                                &s->axi_sram);
+
+    memory_region_init_ram(&s->sram1, NULL, "stm32h745.sram1",
+                           STM32H745_SRAM1_SIZE, &err);
+    if (err) {
+        error_propagate(errp, err);
+        return;
+    }
+    memory_region_add_subregion(system_memory, STM32H745_SRAM1_BASE, &s->sram1);
+
+    memory_region_init_ram(&s->sram2, NULL, "stm32h745.sram2",
+                           STM32H745_SRAM2_SIZE, &err);
+    if (err) {
+        error_propagate(errp, err);
+        return;
+    }
+    memory_region_add_subregion(system_memory, STM32H745_SRAM2_BASE, &s->sram2);
+
+    memory_region_init_ram(&s->sram3, NULL, "stm32h745.sram3",
+                           STM32H745_SRAM3_SIZE, &err);
+    if (err) {
+        error_propagate(errp, err);
+        return;
+    }
+    memory_region_add_subregion(system_memory, STM32H745_SRAM3_BASE, &s->sram3);
+
+    memory_region_init_ram(&s->sram4, NULL, "stm32h745.sram4",
+                           STM32H745_SRAM4_SIZE, &err);
+    if (err) {
+        error_propagate(errp, err);
+        return;
+    }
+    memory_region_add_subregion(system_memory, STM32H745_SRAM4_BASE, &s->sram4);
+
+    if (s->sdram_size) {
+        memory_region_init_ram(&s->sdram, NULL, "stm32h745.sdram",
+                               s->sdram_size, &err);
+        if (err) {
+            error_propagate(errp, err);
+            return;
+        }
+        memory_region_add_subregion(system_memory, STM32H745_SDRAM_BASE,
+                                    &s->sdram);
+    }
+
+    armv7m = DEVICE(&s->armv7m);
+    qdev_prop_set_uint32(armv7m, "num-irq", STM32H745_NUM_IRQ);
+    qdev_prop_set_uint8(armv7m, "num-prio-bits", 4);
+    qdev_prop_set_string(armv7m, "cpu-type", ARM_CPU_TYPE_NAME("cortex-m7"));
+    qdev_prop_set_bit(armv7m, "enable-bitband", true);
+    qdev_connect_clock_in(armv7m, "cpuclk", s->sysclk);
+    qdev_connect_clock_in(armv7m, "refclk", s->refclk);
+    object_property_set_link(OBJECT(&s->armv7m), "memory",
+                             OBJECT(system_memory), &error_abort);
+    if (!sysbus_realize(SYS_BUS_DEVICE(&s->armv7m), errp)) {
+        return;
+    }
+
+    /* RCC */
+    qdev_prop_set_uint32(DEVICE(&s->rcc), "hse-frequency", s->hse_frequency);
+    if (!sysbus_realize(SYS_BUS_DEVICE(&s->rcc), errp)) {
+        return;
+    }
+    sysbus_mmio_map(SYS_BUS_DEVICE(&s->rcc), 0, STM32H745_RCC_BASE);
+
+    /* GPIO ports */
+    for (i = 0; i < STM32H745_NUM_GPIO; i++) {
+        dev = DEVICE(&s->gpio[i]);
+        qdev_prop_set_uint32(dev, "moder-reset", gpio_moder_reset[i]);
+        qdev_prop_set_string(dev, "name", gpio_name[i]);
+        if (!sysbus_realize(SYS_BUS_DEVICE(&s->gpio[i]), errp)) {
+            return;
+        }
+        sysbus_mmio_map(SYS_BUS_DEVICE(&s->gpio[i]), 0, gpio_addr[i]);
+    }
+
+    /* USART1 console */
+    dev = DEVICE(&s->usart1);
+    qdev_prop_set_chr(dev, "chardev", serial_hd(0));
+    if (!sysbus_realize(SYS_BUS_DEVICE(&s->usart1), errp)) {
+        return;
+    }
+    busdev = SYS_BUS_DEVICE(dev);
+    sysbus_mmio_map(busdev, 0, STM32H745_USART1_BASE);
+    sysbus_connect_irq(busdev, 0,
+                       qdev_get_gpio_in(armv7m, STM32H745_USART1_IRQ));
+
+    /*
+     * Unimplemented stubs so firmware walks do not hit unassigned memory
+     * aborts. Expand to real models in later phases.
+     */
+    create_unimplemented_device("pwr",        0x58024800, 0x400);
+    create_unimplemented_device("exti",       0x58000000, 0x400);
+    create_unimplemented_device("syscfg",     0x58000400, 0x400);
+    create_unimplemented_device("flash-if",   0x52002000, 0x1000);
+    create_unimplemented_device("fmc",        0x52004000, 0x1000);
+    create_unimplemented_device("ltdc",       0x50001000, 0x1000);
+    create_unimplemented_device("i2c3",       0x40005C00, 0x400);
+    create_unimplemented_device("tim2",       0x40000000, 0x400);
+    create_unimplemented_device("tim3",       0x40000400, 0x400);
+    create_unimplemented_device("adc1",       0x40022000, 0x400);
+    create_unimplemented_device("dma1",       0x40020000, 0x400);
+    create_unimplemented_device("dma2",       0x40020400, 0x400);
+}
+
+static const Property stm32h745_soc_properties[] = {
+    DEFINE_PROP_UINT32("hse-frequency", STM32H745State, hse_frequency, 0),
+    DEFINE_PROP_UINT64("sdram-size", STM32H745State, sdram_size,
+                       STM32H745_SDRAM_SIZE),
+};
+
+static void stm32h745_soc_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    dc->realize = stm32h745_soc_realize;
+    device_class_set_props(dc, stm32h745_soc_properties);
+}
+
+static const TypeInfo stm32h745_soc_info = {
+    .name = TYPE_STM32H745_SOC,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(STM32H745State),
+    .instance_init = stm32h745_soc_initfn,
+    .class_init = stm32h745_soc_class_init,
+};
+
+static void stm32h745_soc_types(void)
+{
+    type_register_static(&stm32h745_soc_info);
+}
+
+type_init(stm32h745_soc_types)
