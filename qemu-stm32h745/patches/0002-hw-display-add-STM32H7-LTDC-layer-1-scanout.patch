diff --git a/hw/display/stm32h7_ltdc.c b/hw/display/stm32h7_ltdc.c
new file mode 100644
index 0000000..ffae62a
--- /dev/null
+++ b/hw/display/stm32h7_ltdc.c
@@ -0,0 +1,472 @@
+/*
+ * STM32H7 LTDC — application-accurate layer-1 ARGB8888 scanout for ArmOS.
+ *
+ * Copies the guest framebuffer (typically FMC SDRAM @ 0xC0000000) into a
+ * QEMU console surface. Shadow-register reload (SRCR) and GCR/L1CR enable
+ * are enough for the Rust ArmOS LTDC driver.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qemu/log.h"
+#include "qemu/module.h"
+#include "qemu/timer.h"
+#include "hw/display/stm32h7_ltdc.h"
+#include "hw/irq.h"
+#include "hw/qdev-properties.h"
+#include "migration/vmstate.h"
+#include "exec/cpu-common.h"
+#include "ui/console.h"
+#include "ui/pixel_ops.h"
+
+/* ~30 Hz present rate — fine for UI work, not pixel-clock accurate. */
+#define LTDC_REFRESH_NS  (33 * 1000 * 1000)
+
+static bool stm32h7_ltdc_enabled(STM32H7LtdcState *s)
+{
+    return (s->gcr & LTDC_GCR_LTDCEN) && (s->l1cr & LTDC_L1CR_LEN);
+}
+
+static void stm32h7_ltdc_active_size(STM32H7LtdcState *s,
+                                     int *width, int *height)
+{
+    uint32_t ahbp = extract32(s->bpcr, 16, 12);
+    uint32_t avbp = extract32(s->bpcr, 0, 11);
+    uint32_t aaw = extract32(s->awcr, 16, 12);
+    uint32_t aah = extract32(s->awcr, 0, 11);
+    int w = (int)aaw - (int)ahbp;
+    int h = (int)aah - (int)avbp;
+
+    if (w <= 0 || h <= 0) {
+        /* Fall back to layer line count / pitch when timings not programmed. */
+        int pitch = extract32(s->l1cfblr, 16, 13);
+        int lines = extract32(s->l1cfblnr, 0, 11);
+        if (pitch >= 4 && lines > 0) {
+            w = pitch / 4;
+            h = lines;
+        } else {
+            w = 800;
+            h = 480;
+        }
+    }
+
+    if (w < 16) {
+        w = 16;
+    }
+    if (h < 16) {
+        h = 16;
+    }
+    if (w > 2048) {
+        w = 2048;
+    }
+    if (h > 2048) {
+        h = 2048;
+    }
+
+    *width = w;
+    *height = h;
+}
+
+static int stm32h7_ltdc_pitch(STM32H7LtdcState *s, int width)
+{
+    int pitch = extract32(s->l1cfblr, 16, 13);
+
+    if (pitch < width * 4) {
+        pitch = width * 4;
+    }
+    return pitch;
+}
+
+static void stm32h7_ltdc_update_irq(STM32H7LtdcState *s)
+{
+    qemu_set_irq(s->irq, !!(s->isr & s->ier));
+}
+
+static void stm32h7_ltdc_gfx_update(void *opaque)
+{
+    STM32H7LtdcState *s = opaque;
+    DisplaySurface *surface;
+    int width, height, pitch, y;
+    int dest_stride;
+    uint8_t *dst;
+    hwaddr addr;
+    uint32_t pf;
+
+    if (!stm32h7_ltdc_enabled(s) || s->l1cfbar == 0) {
+        return;
+    }
+
+    stm32h7_ltdc_active_size(s, &width, &height);
+    pitch = stm32h7_ltdc_pitch(s, width);
+    addr = s->l1cfbar;
+    pf = s->l1pfcr & 0x7;
+
+    if (s->invalidate) {
+        qemu_console_resize(s->con, width, height);
+        s->invalidate = 0;
+    }
+
+    surface = qemu_console_surface(s->con);
+    if (!surface || surface_width(surface) != width ||
+        surface_height(surface) != height) {
+        qemu_console_resize(s->con, width, height);
+        surface = qemu_console_surface(s->con);
+    }
+    if (!surface) {
+        return;
+    }
+
+    dst = surface_data(surface);
+    dest_stride = surface_stride(surface);
+
+    /*
+     * ArmOS uses LTDC ARGB8888 with guest words 0x00RRGGBB (LE bytes B,G,R,X).
+     * That matches PIXMAN_x8r8g8b8 on little-endian hosts when we copy raw.
+     * RGB565 is converted; other formats fill black.
+     */
+    for (y = 0; y < height; y++) {
+        uint8_t *line = dst + y * dest_stride;
+
+        if (pf == LTDC_PF_ARGB8888 || pf == LTDC_PF_RGB888) {
+            /* RGB888 still stored as 32-bit words in our guest path; copy 32bpp. */
+            cpu_physical_memory_read(addr + (hwaddr)y * pitch, line, width * 4);
+        } else if (pf == LTDC_PF_RGB565) {
+            uint8_t src[2048 * 2];
+            int x;
+
+            cpu_physical_memory_read(addr + (hwaddr)y * pitch, src, width * 2);
+            for (x = 0; x < width; x++) {
+                uint16_t p = lduw_le_p(src + x * 2);
+                uint8_t r = ((p >> 11) & 0x1f) << 3;
+                uint8_t g = ((p >> 5) & 0x3f) << 2;
+                uint8_t b = (p & 0x1f) << 3;
+                stl_le_p(line + x * 4, rgb_to_pixel32(r, g, b));
+            }
+        } else {
+            memset(line, 0, width * 4);
+        }
+    }
+
+    dpy_gfx_update_full(s->con);
+
+    /* Lifeline interrupt (simplified): pulse LIF if enabled. */
+    if (s->ier & (1u << 0)) {
+        s->isr |= (1u << 0);
+        stm32h7_ltdc_update_irq(s);
+    }
+}
+
+static void stm32h7_ltdc_invalidate(void *opaque)
+{
+    STM32H7LtdcState *s = opaque;
+
+    s->invalidate = 1;
+}
+
+static void stm32h7_ltdc_vblank(void *opaque)
+{
+    STM32H7LtdcState *s = opaque;
+
+    if (stm32h7_ltdc_enabled(s)) {
+        stm32h7_ltdc_gfx_update(s);
+    }
+    timer_mod(s->vblank_timer,
+              qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) + LTDC_REFRESH_NS);
+}
+
+static void stm32h7_ltdc_reload(STM32H7LtdcState *s)
+{
+    /*
+     * Hardware reloads shadow registers here. We apply writes immediately,
+     * so reload just forces a full redraw with the current CFBAR/geometry.
+     */
+    s->invalidate = 1;
+    if (stm32h7_ltdc_enabled(s)) {
+        stm32h7_ltdc_gfx_update(s);
+        timer_mod(s->vblank_timer,
+                  qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) + LTDC_REFRESH_NS);
+    }
+}
+
+static uint64_t stm32h7_ltdc_read(void *opaque, hwaddr addr, unsigned size)
+{
+    STM32H7LtdcState *s = opaque;
+
+    switch (addr) {
+    case LTDC_SSCR:
+        return s->sscr;
+    case LTDC_BPCR:
+        return s->bpcr;
+    case LTDC_AWCR:
+        return s->awcr;
+    case LTDC_TWCR:
+        return s->twcr;
+    case LTDC_GCR:
+        return s->gcr;
+    case LTDC_SRCR:
+        return 0;
+    case LTDC_BCCR:
+        return s->bccr;
+    case LTDC_IER:
+        return s->ier;
+    case LTDC_ISR:
+        return s->isr;
+    case LTDC_ICR:
+        return 0;
+    case LTDC_LIPCR:
+        return s->lipcr;
+    case LTDC_CPSR:
+        return 0;
+    case LTDC_CDSR:
+        /* VSYNC/HSYNC/etc idle-high-ish status */
+        return 0xF;
+    case LTDC_L1CR:
+        return s->l1cr;
+    case LTDC_L1WHPCR:
+        return s->l1whpcr;
+    case LTDC_L1WVPCR:
+        return s->l1wvpcr;
+    case LTDC_L1CKCR:
+        return s->l1ckcr;
+    case LTDC_L1PFCR:
+        return s->l1pfcr;
+    case LTDC_L1CACR:
+        return s->l1cacr;
+    case LTDC_L1DCCR:
+        return s->l1dccr;
+    case LTDC_L1BFCR:
+        return s->l1bfcr;
+    case LTDC_L1CFBAR:
+        return s->l1cfbar;
+    case LTDC_L1CFBLR:
+        return s->l1cfblr;
+    case LTDC_L1CFBLNR:
+        return s->l1cfblnr;
+    default:
+        qemu_log_mask(LOG_UNIMP,
+                      "stm32h7_ltdc: read offset 0x%" HWADDR_PRIx "\n", addr);
+        return 0;
+    }
+}
+
+static void stm32h7_ltdc_write(void *opaque, hwaddr addr,
+                               uint64_t val64, unsigned size)
+{
+    STM32H7LtdcState *s = opaque;
+    uint32_t value = val64;
+
+    switch (addr) {
+    case LTDC_SSCR:
+        s->sscr = value;
+        break;
+    case LTDC_BPCR:
+        s->bpcr = value;
+        s->invalidate = 1;
+        break;
+    case LTDC_AWCR:
+        s->awcr = value;
+        s->invalidate = 1;
+        break;
+    case LTDC_TWCR:
+        s->twcr = value;
+        break;
+    case LTDC_GCR:
+        s->gcr = value;
+        if (stm32h7_ltdc_enabled(s)) {
+            s->invalidate = 1;
+            timer_mod(s->vblank_timer,
+                      qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) + LTDC_REFRESH_NS);
+        } else {
+            timer_del(s->vblank_timer);
+        }
+        break;
+    case LTDC_SRCR:
+        if (value & (LTDC_SRCR_IMR | LTDC_SRCR_VBR)) {
+            stm32h7_ltdc_reload(s);
+        }
+        break;
+    case LTDC_BCCR:
+        s->bccr = value & 0xFFFFFF;
+        break;
+    case LTDC_IER:
+        s->ier = value & 0x1F;
+        stm32h7_ltdc_update_irq(s);
+        break;
+    case LTDC_ICR:
+        s->isr &= ~value;
+        stm32h7_ltdc_update_irq(s);
+        break;
+    case LTDC_LIPCR:
+        s->lipcr = value & 0x7FF;
+        break;
+    case LTDC_L1CR:
+        s->l1cr = value;
+        if (stm32h7_ltdc_enabled(s)) {
+            s->invalidate = 1;
+            timer_mod(s->vblank_timer,
+                      qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) + LTDC_REFRESH_NS);
+        }
+        break;
+    case LTDC_L1WHPCR:
+        s->l1whpcr = value;
+        break;
+    case LTDC_L1WVPCR:
+        s->l1wvpcr = value;
+        break;
+    case LTDC_L1CKCR:
+        s->l1ckcr = value;
+        break;
+    case LTDC_L1PFCR:
+        s->l1pfcr = value & 0x7;
+        s->invalidate = 1;
+        break;
+    case LTDC_L1CACR:
+        s->l1cacr = value & 0xFF;
+        break;
+    case LTDC_L1DCCR:
+        s->l1dccr = value;
+        break;
+    case LTDC_L1BFCR:
+        s->l1bfcr = value;
+        break;
+    case LTDC_L1CFBAR:
+        s->l1cfbar = value;
+        break;
+    case LTDC_L1CFBLR:
+        s->l1cfblr = value;
+        s->invalidate = 1;
+        break;
+    case LTDC_L1CFBLNR:
+        s->l1cfblnr = value & 0x7FF;
+        s->invalidate = 1;
+        break;
+    case LTDC_L1CLUTWR:
+        /* CLUT not modelled */
+        break;
+    case LTDC_ISR:
+    case LTDC_CPSR:
+    case LTDC_CDSR:
+        /* read-only */
+        break;
+    default:
+        qemu_log_mask(LOG_UNIMP,
+                      "stm32h7_ltdc: write offset 0x%" HWADDR_PRIx
+                      " value 0x%" PRIx32 "\n", addr, value);
+        break;
+    }
+}
+
+static const MemoryRegionOps stm32h7_ltdc_ops = {
+    .read = stm32h7_ltdc_read,
+    .write = stm32h7_ltdc_write,
+    .endianness = DEVICE_NATIVE_ENDIAN,
+    .valid.min_access_size = 4,
+    .valid.max_access_size = 4,
+};
+
+static const GraphicHwOps stm32h7_ltdc_gfx_ops = {
+    .invalidate = stm32h7_ltdc_invalidate,
+    .gfx_update = stm32h7_ltdc_gfx_update,
+};
+
+static void stm32h7_ltdc_reset(DeviceState *dev)
+{
+    STM32H7LtdcState *s = STM32H7_LTDC(dev);
+
+    s->sscr = 0;
+    s->bpcr = 0;
+    s->awcr = 0;
+    s->twcr = 0;
+    s->gcr = 0x2220; /* reset value per RM (DEN/PCPOL etc defaults) */
+    s->bccr = 0;
+    s->ier = 0;
+    s->isr = 0;
+    s->lipcr = 0;
+    s->l1cr = 0;
+    s->l1whpcr = 0;
+    s->l1wvpcr = 0;
+    s->l1ckcr = 0;
+    s->l1pfcr = 0;
+    s->l1cacr = 0xFF;
+    s->l1dccr = 0;
+    s->l1bfcr = 0x607;
+    s->l1cfbar = 0;
+    s->l1cfblr = 0;
+    s->l1cfblnr = 0;
+    s->invalidate = 1;
+    timer_del(s->vblank_timer);
+}
+
+static void stm32h7_ltdc_realize(DeviceState *dev, Error **errp)
+{
+    STM32H7LtdcState *s = STM32H7_LTDC(dev);
+
+    s->con = graphic_console_init(dev, 0, &stm32h7_ltdc_gfx_ops, s);
+    qemu_console_resize(s->con, 800, 480);
+}
+
+static void stm32h7_ltdc_init(Object *obj)
+{
+    STM32H7LtdcState *s = STM32H7_LTDC(obj);
+    SysBusDevice *sbd = SYS_BUS_DEVICE(obj);
+
+    memory_region_init_io(&s->iomem, obj, &stm32h7_ltdc_ops, s,
+                          TYPE_STM32H7_LTDC, 0x1000);
+    sysbus_init_mmio(sbd, &s->iomem);
+    sysbus_init_irq(sbd, &s->irq);
+    sysbus_init_irq(sbd, &s->irq_err);
+
+    s->vblank_timer = timer_new_ns(QEMU_CLOCK_VIRTUAL, stm32h7_ltdc_vblank, s);
+}
+
+static const VMStateDescription vmstate_stm32h7_ltdc = {
+    .name = TYPE_STM32H7_LTDC,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (const VMStateField[]) {
+        VMSTATE_UINT32(sscr, STM32H7LtdcState),
+        VMSTATE_UINT32(bpcr, STM32H7LtdcState),
+        VMSTATE_UINT32(awcr, STM32H7LtdcState),
+        VMSTATE_UINT32(twcr, STM32H7LtdcState),
+        VMSTATE_UINT32(gcr, STM32H7LtdcState),
+        VMSTATE_UINT32(bccr, STM32H7LtdcState),
+        VMSTATE_UINT32(ier, STM32H7LtdcState),
+        VMSTATE_UINT32(isr, STM32H7LtdcState),
+        VMSTATE_UINT32(lipcr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1cr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1whpcr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1wvpcr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1pfcr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1cacr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1bfcr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1cfbar, STM32H7LtdcState),
+        VMSTATE_UINT32(l1cfblr, STM32H7LtdcState),
+        VMSTATE_UINT32(l1cfblnr, STM32H7LtdcState),
+        VMSTATE_END_OF_LIST()
+    }
+};
+
+static void stm32h7_ltdc_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    dc->realize = stm32h7_ltdc_realize;
+    device_class_set_legacy_reset(dc, stm32h7_ltdc_reset);
+    dc->vmsd = &vmstate_stm32h7_ltdc;
+}
+
+static const TypeInfo stm32h7_ltdc_info = {
+    .name = TYPE_STM32H7_LTDC,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(STM32H7LtdcState),
+    .instance_init = stm32h7_ltdc_init,
+    .class_init = stm32h7_ltdc_class_init,
+};
+
+static void stm32h7_ltdc_register_types(void)
+{
+    type_register_static(&stm32h7_ltdc_info);
+}
+
+type_init(stm32h7_ltdc_register_types)
diff --git a/include/hw/arm/stm32h745_soc.h b/include/hw/arm/stm32h745_soc.h
index 3d07dad..f660928 100644
--- a/include/hw/arm/stm32h745_soc.h
+++ b/include/hw/arm/stm32h745_soc.h
@@ -9,6 +9,7 @@
 
 #include "hw/arm/armv7m.h"
 #include "hw/char/stm32h7_usart.h"
+#include "hw/display/stm32h7_ltdc.h"
 #include "hw/gpio/stm32h7_gpio.h"
