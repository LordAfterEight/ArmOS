 hw/arm/stm32h745_soc.c            |  12 +-
 hw/display/Kconfig                |   3 +
 hw/display/meson.build            |   1 +
 hw/display/stm32h7_ltdc.c         | 472 ++++++++++++++++++++++++++++++
 include/hw/arm/stm32h745_soc.h    |   5 +
 include/hw/display/stm32h7_ltdc.h |  92 ++++++
 7 files changed, 585 insertions(+), 1 deletion(-)
 create mode 100644 hw/display/stm32h7_ltdc.c
 create mode 100644 include/hw/display/stm32h7_ltdc.h

