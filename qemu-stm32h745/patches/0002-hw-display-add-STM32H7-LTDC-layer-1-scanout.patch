+/*
+ * STM32H7 LTDC (LCD-TFT Display Controller) — single-layer scanout
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef HW_DISPLAY_STM32H7_LTDC_H
+#define HW_DISPLAY_STM32H7_LTDC_H
+
+#include "hw/sysbus.h"
+#include "ui/console.h"
+#include "qom/object.h"
+
+#define TYPE_STM32H7_LTDC "stm32h7-ltdc"
+OBJECT_DECLARE_SIMPLE_TYPE(STM32H7LtdcState, STM32H7_LTDC)
+
+/* Global registers */
+#define LTDC_SSCR   0x08
+#define LTDC_BPCR   0x0C
+#define LTDC_AWCR   0x10
+#define LTDC_TWCR   0x14
+#define LTDC_GCR    0x18
+#define LTDC_SRCR   0x24
+#define LTDC_BCCR   0x2C
+#define LTDC_IER    0x34
+#define LTDC_ISR    0x38
+#define LTDC_ICR    0x3C
+#define LTDC_LIPCR  0x40
+#define LTDC_CPSR   0x44
+#define LTDC_CDSR   0x48
+
+/* Layer 1 */
+#define LTDC_L1CR      0x84
+#define LTDC_L1WHPCR   0x88
+#define LTDC_L1WVPCR   0x8C
+#define LTDC_L1CKCR    0x90
+#define LTDC_L1PFCR    0x94
+#define LTDC_L1CACR    0x98
+#define LTDC_L1DCCR    0x9C
+#define LTDC_L1BFCR    0xA0
+#define LTDC_L1CFBAR   0xAC
+#define LTDC_L1CFBLR   0xB0
+#define LTDC_L1CFBLNR  0xB4
+#define LTDC_L1CLUTWR  0xC4
+
+#define LTDC_GCR_LTDCEN   (1u << 0)
+#define LTDC_SRCR_IMR     (1u << 0)
+#define LTDC_SRCR_VBR     (1u << 1)
+#define LTDC_L1CR_LEN     (1u << 0)
+
+/* PFCR pixel format */
+#define LTDC_PF_ARGB8888  0
+#define LTDC_PF_RGB888    1
+#define LTDC_PF_RGB565    2
+#define LTDC_PF_ARGB1555  3
+#define LTDC_PF_ARGB4444  4
+
+struct STM32H7LtdcState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion iomem;
+    QemuConsole *con;
+    QEMUTimer *vblank_timer;
+    qemu_irq irq;
+    qemu_irq irq_err;
+
+    uint32_t sscr;
+    uint32_t bpcr;
+    uint32_t awcr;
+    uint32_t twcr;
+    uint32_t gcr;
+    uint32_t bccr;
+    uint32_t ier;
+    uint32_t isr;
+    uint32_t lipcr;
+
+    uint32_t l1cr;
+    uint32_t l1whpcr;
+    uint32_t l1wvpcr;
+    uint32_t l1ckcr;
+    uint32_t l1pfcr;
+    uint32_t l1cacr;
+    uint32_t l1dccr;
+    uint32_t l1bfcr;
+    uint32_t l1cfbar;
+    uint32_t l1cfblr;
+    uint32_t l1cfblnr;
+
+    int invalidate;
+};
+
+#endif /* HW_DISPLAY_STM32H7_LTDC_H */
